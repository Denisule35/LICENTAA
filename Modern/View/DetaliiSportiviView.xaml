<Window x:Class="Modern.View.DetaliiSportiviView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Modern.View"
        mc:Ignorable="d"
        Title="DetaliiSportivi"
        Height="800" Width="1200"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Storyboard x:Key="SlideInFromRight">
            <DoubleAnimation
                Storyboard.TargetName="RootBorder"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                From="400" To="0"
                Duration="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="RootBorder"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1"
                Duration="0:0:0.35"/>
        </Storyboard>

        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Height="38"
                                CornerRadius="10"
                                Background="{Binding Galben}">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8A400" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Height="38"
                                CornerRadius="10"
                                Background="{Binding Rosu}">
                            <Border.Effect>
                                <DropShadowEffect Color="#CC2200" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="8">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                  Style="{x:Null}" Template="{x:Null}"
                                                  Background="Transparent" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{Binding Galben}" CornerRadius="4" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                  Style="{x:Null}" Template="{x:Null}"
                                                  Background="Transparent" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SportListItem" TargetType="{x:Type ListViewItem}">
            <Setter Property="Margin" Value="4,3,4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{Binding DataContext.Negru, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{Binding DataContext.Negru, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Outer shadow -->
        <Border Margin="10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>
            <Border Background="Transparent" CornerRadius="22"/>
        </Border>

        <!-- Main animated border -->
        <Border x:Name="RootBorder"
                Background="{Binding Gri}"
                BorderBrush="{Binding Galben}"
                BorderThickness="1.5"
                CornerRadius="22"
                Margin="10"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ HEADER ═══ -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top gold accent strip spans all columns -->
                    <Border Grid.Column="0" Grid.ColumnSpan="3"
                            Height="4" VerticalAlignment="Top"
                            CornerRadius="22,22,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C8A400" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Profile photo -->
                    <Button Grid.Column="0"
                            Command="{Binding AdaugarePoza}"
                            BorderThickness="0"
                            Background="Transparent"
                            Cursor="Hand"
                            Margin="18,15,0,15"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Width="116" Height="116">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#80C8A400" Offset="0.7"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Width="108" Height="108"
                                             StrokeThickness="2"
                                             Stroke="{Binding Galben}"/>
                                    <Ellipse Width="102" Height="102">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfileImage}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Athlete name -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock FontSize="46"
                                   FontFamily="Georgia"
                                   FontWeight="Bold"
                                   Foreground="{Binding Galben}"
                                   Text="{Binding nume}"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#C8A400" BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <Rectangle Height="1.5" Width="220" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#C8A400" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock Text="NIVEL:"
               Foreground="{Binding Galben}"
               FontFamily="Consolas"
               FontSize="11"
               FontWeight="Bold"
               VerticalAlignment="Center"
               Opacity="0.7"
               Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding NiveluriExperienta}"
              SelectedItem="{Binding NivelExperienta, Mode=TwoWay}"
              Width="160"
              Cursor="Hand">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Background" Value="{Binding Negru}"/>
                                        <Setter Property="Foreground" Value="{Binding Galben}"/>
                                        <Setter Property="BorderBrush" Value="{Binding Galben}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                           Foreground="{Binding DataContext.Galben,
                               RelativeSource={RelativeSource AncestorType=ComboBox}}"
                           FontFamily="Consolas"
                           FontSize="13"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                    </StackPanel>

                    <!-- Close button -->
                    <Button Grid.Column="2"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="0,16,16,0"
                            BorderThickness="0"
                            Content="✕"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="Iesire">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBd"
                                        Height="34" Width="34"
                                        CornerRadius="10"
                                        Background="{Binding Rosu}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#CC2200" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>

                <!-- ═══ BODY ═══ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── PUNCTE TARI ── -->
                    <Grid Grid.Column="0" Margin="12,8,6,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="PUNCTE TARI"
                                   Foreground="ForestGreen"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Opacity="0.9"
                                   Margin="4,0,0,6"/>

                        <Border Grid.Row="1"
                                Background="{Binding Negru}"
                                CornerRadius="10"
                                Padding="10,0"
                                BorderBrush="ForestGreen"
                                BorderThickness="1">
                            <TextBox Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="ForestGreen"
                                     CaretBrush="ForestGreen"
                                     Text="{Binding PunctTareTextbox, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"/>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,8,0,0"
                                CornerRadius="12"
                                Background="{Binding Negru}"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1">
                            <ListView Background="Transparent"
                                      BorderThickness="0"
                                      ItemsSource="{Binding PuncteTari}"
                                      SelectedItem="{Binding SelectedPunctTare, Mode=TwoWay}"
                                      ItemContainerStyle="{StaticResource SportListItem}">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBar}"/>
                                </ListView.Resources>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                                            <Ellipse Width="7" Height="7" Fill="ForestGreen"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="ForestGreen"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Command="{Binding AdaugarePunctTare}"
                                    Style="{StaticResource GoldButton}"
                                    Margin="0,12,5,0"
                                    FontSize="13"
                                    FontFamily="Consolas"
                                    FontWeight="Bold"
                                    Foreground="{Binding Gri}"
                                    Content="+ ADAUGARE"/>
                            <Button Grid.Column="1"
                                    Command="{Binding StergerePunctTare}"
                                    Style="{StaticResource RedButton}"
                                    Margin="5,12,0,0"
                                    FontSize="13"
                                    FontFamily="Consolas"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Content="− STERGERE"/>
                        </Grid>
                    </Grid>

                    <!-- Divider col 0 -->
                    <Rectangle Grid.Column="0"
                               Width="1" HorizontalAlignment="Right"
                               Margin="0,10,0,10">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#40C8A400" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ── PUNCTE SLABE ── -->
                    <Grid Grid.Column="1" Margin="6,8,6,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="PUNCTE SLABE"
                                   Foreground="{Binding Rosu}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Opacity="0.9"
                                   Margin="4,0,0,6"/>

                        <Border Grid.Row="1"
                                Background="{Binding Negru}"
                                CornerRadius="10"
                                Padding="10,0"
                                BorderBrush="{Binding Rosu}"
                                BorderThickness="1">
                            <TextBox Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{Binding Rosu}"
                                     CaretBrush="{Binding Rosu}"
                                     Text="{Binding PunctSlabTextbox, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"/>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,8,0,0"
                                CornerRadius="12"
                                Background="{Binding Negru}"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1">
                            <ListView Background="Transparent"
                                      BorderThickness="0"
                                      ItemsSource="{Binding PuncteSlabe}"
                                      SelectedItem="{Binding SelectedPunctSlab, Mode=TwoWay}"
                                      ItemContainerStyle="{StaticResource SportListItem}">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBar}"/>
                                </ListView.Resources>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                                            <Ellipse Width="7" Height="7"
                                                     Fill="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Command="{Binding AdaugarePunctSlab}"
                                    Style="{StaticResource GoldButton}"
                                    Margin="0,12,5,0"
                                    FontSize="13"
                                    FontFamily="Consolas"
                                    FontWeight="Bold"
                                    Foreground="{Binding Gri}"
                                    Content="+ ADAUGARE"/>
                            <Button Grid.Column="1"
                                    Command="{Binding StergerePunctSlab}"
                                    Style="{StaticResource RedButton}"
                                    Margin="5,12,0,0"
                                    FontSize="13"
                                    FontFamily="Consolas"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Content="− STERGERE"/>
                        </Grid>
                    </Grid>

                    <!-- Divider col 1 -->
                    <Rectangle Grid.Column="1"
                               Width="1" HorizontalAlignment="Right"
                               Margin="0,10,0,10">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#40C8A400" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ── STATISTICI ── -->
                    <Grid Grid.Column="2" Margin="6,8,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="STATISTICI"
                                   Foreground="{Binding Galben}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Opacity="0.9"
                                   Margin="4,0,0,6"/>

                        <Border Grid.Row="1"
            Background="{Binding Negru}"
            CornerRadius="10"
            Padding="12,8"
            BorderBrush="#22C8A400"
            BorderThickness="1"
            Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PREZENȚĂ:"
                       Foreground="{Binding Galben}"
                       FontFamily="Consolas"
                       FontSize="11"
                       FontWeight="Bold"
                       Opacity="0.7"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Procentajprezenta, StringFormat={}{0}%}"
                       Foreground="{Binding Galben}"
                       FontFamily="Consolas"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#C8A400" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                CornerRadius="16"
                                Background="{Binding Negru}"
                                BorderBrush="#22C8A400"
                                BorderThickness="1">
                            <lvc:PieChart SeriesSource="{Binding PieChartt}" Margin="8"
                                          Background="{Binding DataContext.Negru, RelativeSource={RelativeSource AncestorType=Window}}">
                                <lvc:PieChart.SeriesTemplate>
                                    <DataTemplate>
                                        <lvc:XamlPieSeries SeriesName="{Binding Name}" Values="{Binding Values}"/>
                                    </DataTemplate>
                                </lvc:PieChart.SeriesTemplate>
                                <lvc:PieChart.Title>
                                    <lvc:XamlDrawnLabelVisual
                                        Text="Profil Sportiv"
                                        Paint="#C8A400"
                                        TextSize="18"
                                        Padding="10"/>
                                </lvc:PieChart.Title>
                            </lvc:PieChart>
                        </Border>
                    </Grid>

                </Grid>

            </Grid>
        </Border>

    </Grid>
</Window>
