<Window x:Class="Modern.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Modern.View"
        xmlns:vm="clr-namespace:Modern.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{Binding Gri}"
        d:DesignWidth="750" d:DesignHeight="500">

    <Window.Resources>
        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.5"
                           AccelerationRatio="0.3"/>
        </Storyboard>

        <!-- Slide In From Left Animation -->
        <Storyboard x:Key="SlideInLeft">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="-100" To="0" Duration="0:0:0.6"
                           AccelerationRatio="0.3" DecelerationRatio="0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Button Hover Scale Animation -->
        <Style x:Key="AnimatedButtonStyle" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{Binding Gri}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{Binding Galben}"/>
            <Setter Property="Foreground" Value="{Binding Rosu}"/>
            <Setter Property="CaretBrush" Value="{Binding Rosu}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetProperty="BorderThickness"
                                                  To="0,0,0,3" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetProperty="BorderThickness"
                                                  To="0,0,0,2" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid Background="{Binding Gri}" Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar with Modern Card Design -->
        <Border Background="{Binding Negru}" 
                BorderBrush="{Binding Galben}" 
                BorderThickness="0" 
                CornerRadius="15"
                Opacity="0"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="5"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform X="-50"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0" To="1" Duration="0:0:0.6"
                                           BeginTime="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                           From="-50" To="0" Duration="0:0:0.6"
                                           BeginTime="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- Section Title -->
                <TextBlock Text="MANAGEMENT" 
                           Foreground="{Binding Galben}" 
                           FontSize="16" 
                           FontWeight="Bold"
                           HorizontalAlignment="Left"
                           Margin="5,0,0,0"/>

                <Rectangle Grid.Row="1" 
                           Height="2" 
                           Fill="{Binding Galben}" 
                           Opacity="0.3"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,5"/>

                <!-- Spacer -->
                <Border Grid.Row="2"/>


                <Button Grid.Row="14"
Background="{Binding Gri}" 
Foreground="{Binding Galben}" 
Cursor="Hand" 
Command="{Binding DeschidereFinante}" 
FontSize="15"
FontWeight="SemiBold"
Height="60"
Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
            Background="{TemplateBinding Background}" 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                            Opacity="0.3" 
                            BlurRadius="10" 
                            ShadowDepth="3"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                                    <TextBlock Text="+" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>
                                    <TextBlock Text="Finante" 
                       FontSize="15" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <Button Grid.Row="12"
Background="{Binding Gri}" 
Foreground="{Binding Galben}" 
Cursor="Hand" 
Command="{Binding DeschiderePrezenta}" 
FontSize="15"
FontWeight="SemiBold"
Height="60"
Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
            Background="{TemplateBinding Background}" 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                            Opacity="0.3" 
                            BlurRadius="10" 
                            ShadowDepth="3"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                                    <TextBlock Text="+" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"/>
                                    <TextBlock Text="Prezenta" 
                       FontSize="15" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Row="8"
        Background="{Binding Gri}" 
        Foreground="{Binding Galben}" 
        Cursor="Hand" 
        Command="{Binding DeschidereAnalizaAi}" 
        FontSize="15"
        FontWeight="SemiBold"
        Height="60"
        Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
                    Background="{TemplateBinding Background}" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                    Opacity="0.3" 
                                    BlurRadius="10" 
                                    ShadowDepth="3"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                                    <TextBlock Text="+" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Analiza AI" 
                               FontSize="15" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Add Trainer Button with Icon -->
                <Button Grid.Row="4"
                        Background="{Binding Galben}" 
                        Foreground="{Binding Negru}" 
                        Cursor="Hand" 
                        Command="{Binding DeschidereAdgAdmin}" 
                        FontSize="15"
                        FontWeight="SemiBold"
                        Height="60"
                        Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
                                    Background="{TemplateBinding Background}" 
                                    HorizontalAlignment="Stretch" 
                                    VerticalAlignment="Stretch">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                                    Opacity="0.3" 
                                                    BlurRadius="10" 
                                                    ShadowDepth="3"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center">
                                    <TextBlock Text="+" 
                                               FontSize="24" 
                                               FontWeight="Bold" 
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Adaugă Antrenor" 
                                               FontSize="15" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Delete Trainer Button with Icon -->
                <Button Grid.Row="6"
                        Background="Transparent" 
                        BorderBrush="{Binding Rosu}"
                        BorderThickness="2"
                        Foreground="{Binding Rosu}" 
                        Cursor="Hand" 
                        Command="{Binding DeschidereStergereAdmin}" 
                        FontSize="15"
                        FontWeight="SemiBold"
                        Height="60"
                        Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    HorizontalAlignment="Stretch" 
                                    VerticalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center">
                                    <TextBlock Text="×" 
                                               FontSize="28" 
                                               FontWeight="Bold" 
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Rosu}"/>
                                    <TextBlock Text="Șterge Antrenor" 
                                               FontSize="15" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Rosu}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Row="10"
        Background="Transparent" 
        BorderBrush="{Binding Galben}"
        BorderThickness="2"
        Foreground="{Binding Galben}" 
        Cursor="Hand" 
        Command="{Binding DeschidereInventar}" 
        FontSize="15"
        FontWeight="SemiBold"
        Height="60"
        Style="{StaticResource AnimatedButtonStyle}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                                    <TextBlock Text="×" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{Binding Galben}"/>
                                    <TextBlock Text="Inventar" 
                               FontSize="15" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{Binding Galben}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Modern Header Card -->
            <Border Background="{Binding Negru}" 
                    CornerRadius="15" 
                    Padding="20,15">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="5"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Section -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" 
                                   FontSize="20" 
                                   Margin="0,0,10,0" 
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Galben}"/>
                        <TextBox Width="200" 
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Filtru, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Background="{Binding Negru}"/>

                        <TextBlock Text="Preț Abonament:" 
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="{Binding Galben}"
               VerticalAlignment="Center"
               Margin="20,0,10,0"/>
                        <TextBox Width="120" 
             Style="{StaticResource ModernTextBox}"
             Text="{Binding PretAbonament, UpdateSourceTrigger=PropertyChanged}"
             VerticalContentAlignment="Center"
             FontSize="14"
             PreviewTextInput="TextBox_PreviewTextInput"
             Background="{Binding Negru}"/>

                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">

                        <!-- Theme Toggle Button -->
                        <Button Command="{Binding SchimbareTema}" 
                                Cursor="Hand"
                                Style="{StaticResource AnimatedButtonStyle}"
                                Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{Binding Galben}" 
                                            Padding="8" 
                                            Width="40"
                                            Height="40"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush ImageSource="/imagini/bec.png" Stretch="Uniform"/>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Minimize Button -->
                        <Button x:Name="btnminimize"
                                BorderThickness="0"
                                Content="−"
                                Foreground="White"
                                FontSize="20"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Butonminimize"
                                Width="40"
                                Height="40"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{Binding Galben}"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFA726"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                       To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                       To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" 
                                            Background="{TemplateBinding Background}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Close Button -->
                        <Button x:Name="btnexit"
                                BorderThickness="0"
                                Content="×"
                                FontSize="24"
                                FontWeight="Bold"
                                Foreground="White"
                                Cursor="Hand"
                                Click="Butonclose"
                                Width="40"
                                Height="40">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{Binding Rosu}"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D32F2F"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                       To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                       To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10" 
                                            Background="{TemplateBinding Background}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                        </Border.Effect>
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Card -->
            <Border Grid.Row="2" 
                    Background="{Binding Negru}" 
                    CornerRadius="15" 
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="MEMBRI ACTIVI" 
                                   Foreground="{Binding Galben}" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Total: " 
                                       Foreground="{Binding Galben}" 
                                       FontSize="14" 
                                       Opacity="0.7"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Oameni.Count}" 
                                       Foreground="{Binding Galben}" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separator Line -->
                    <Rectangle Grid.Row="1" 
                               Height="1" 
                               Fill="{Binding Galben}" 
                               Opacity="0.2"
                               VerticalAlignment="Center"/>

                    <!-- Members List -->
                    <ListView Grid.Row="2"
                          Background="Transparent" 
                          BorderThickness="0"  
                          ItemsSource="{Binding Oameni}">
                        <ListView.Resources>
                            <!-- Custom Scrollbar Style -->
                            <Style TargetType="{x:Type ScrollBar}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent">
                                                <Track Name="PART_Track" IsDirectionReversed="true" Width="13">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="ScrollBar.LineUpCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{Binding Galben}" 
                                                                        BorderBrush="{Binding Galben}" 
                                                                        CornerRadius="10" 
                                                                        Margin="2">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Trigger.EnterActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                               To="0.8" Duration="0:0:0.2"/>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.EnterActions>
                                                                                        <Trigger.ExitActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                               To="1" Duration="0:0:0.2"/>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.ExitActions>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="ScrollBar.LineDownCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="Margin" Value="0,5,0,5"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="20"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListViewItem}">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="1" Duration="0:0:0.4"
                                                           BeginTime="0:0:0.1">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                           To="0" Duration="0:0:0.4"
                                                           BeginTime="0:0:0.1">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Gri}" 
                                    Cursor="Hand" 
                                    BorderBrush="{Binding Galben}" 
                                    BorderThickness="0,0,0,2" 
                                    CornerRadius="18"
                                    Padding="15,12"
                                        Width="1550">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0" BlurRadius="15" ShadowDepth="5"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                           To="0.3" Duration="0:0:0.2"/>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                              To="-2" Duration="0:0:0.2">
                                                                    <ThicknessAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </ThicknessAnimation.EasingFunction>
                                                                </ThicknessAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                           To="0" Duration="0:0:0.2"/>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                              To="0" Duration="0:0:0.2">
                                                                    <ThicknessAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </ThicknessAnimation.EasingFunction>
                                                                </ThicknessAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status Indicator with Pulse Animation -->
                                        <Border Grid.Column="0" 
                                            Width="12" 
                                            Height="12" 
                                            CornerRadius="6"
                                            Background="{Binding expirat}"
                                            VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding expirat}" Value="Red">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                   From="1" To="0.3" Duration="0:0:1"
                                                                                   AutoReverse="True">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <SineEase EasingMode="EaseInOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <TextBlock Grid.Column="2" 
                                               Text="{Binding nume}" 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Left" 
                                               Foreground="{Binding Galben}" 
                                               FontFamily="Segoe UI" 
                                               FontSize="16"
                                               FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="3" 
                                               Text="{Binding data}" 
                                               HorizontalAlignment="Right" 
                                               VerticalAlignment="Center" 
                                               Foreground="{Binding Galben}" 
                                               FontFamily="Segoe UI" 
                                               FontSize="14"
                                               Opacity="0.8"/>

                                        <!-- Action Buttons with Hover Animations -->
                                        <Button Grid.Column="5" 
                                            Margin="10,0,8,0" 
                                            Command="{Binding StergereOm}"
                                            ToolTip="Șterge membru"
                                            Style="{StaticResource AnimatedButtonStyle}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{Binding Rosu}" 
                                                        CornerRadius="8" 
                                                        Padding="10,8" 
                                                        RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                                        </Border.Effect>
                                                        <Border Width="25" Height="25">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="/imagini/gunoi.png" Stretch="UniformToFill"/>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Grid.Column="6" 
                                            Margin="0,0,8,0" 
                                            Command="{Binding RenoireAbonament}"
                                            ToolTip="Reînnoiește abonament"
                                            Style="{StaticResource AnimatedButtonStyle}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{Binding Negru}" 
                                                        CornerRadius="8" 
                                                        Padding="10,8" 
                                                        RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                                        </Border.Effect>
                                                        <Border Width="25" Height="25">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="/imagini/renoire.png" Stretch="UniformToFill"/>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Grid.Column="7" 
                                            Command="{Binding DeschidereDetaliSportiv}"
                                            ToolTip="Detalii membru"
                                            Style="{StaticResource AnimatedButtonStyle}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{Binding Negru}" 
                                                        CornerRadius="8" 
                                                        Padding="10,8" 
                                                        RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                                        </Border.Effect>
                                                        <Border Width="25" Height="25">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="/imagini/informatikickboxer.png" Stretch="UniformToFill"/>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Add Member Button -->
                    <Button Grid.Row="4" 
                        Height="90" 
                        Command="{Binding DeschidereAdgOm}" 
                        Background="{Binding Galben}" 
                        Cursor="Hand"
                        Style="{StaticResource AnimatedButtonStyle}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" 
                                    Background="{TemplateBinding Background}" 
                                    HorizontalAlignment="Stretch" 
                                    VerticalAlignment="Stretch" 
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="5"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="60" Height="60" CornerRadius="10">
                                            <Border.Background>
                                                <ImageBrush ImageSource="/imagini/kickboxer.png" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel Grid.Column="1" 
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="20,0,0,0">
                                            <TextBlock Text="Adaugă Membru Nou" 
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Negru}"/>
                                            <TextBlock Text="Apasă pentru a înregistra un sportiv" 
                                                   FontSize="12" 
                                                   Opacity="0.7"
                                                   Foreground="{Binding Negru}"
                                                   Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
