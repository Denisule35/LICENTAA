<Window x:Class="Modern.View.InventarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             Title="Inventar — Kickboxing Manager"
             Height="750" Width="1200"
             MinWidth="900" MinHeight="550"
             WindowStartupLocation="CenterScreen"
             WindowStyle="SingleBorderWindow"
             Background="#242222">

    <Window.Resources>

        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{Binding Galben, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CornerRadius="3" Opacity="0.6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="50" CenterY="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{Binding Gri, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="8"
                                BorderThickness="1.5"
                                BorderBrush="Transparent">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{Binding Galben, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ArticleCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════════
             LISTBOXITEM — removes default hover/selected highlight
        ══════════════════════════════════════════════ -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{Binding Negru}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 · HEADER -->
        <Border Grid.Row="0"
                Background="{Binding Gri}"
                Padding="28,18,28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4" Height="36" CornerRadius="2"
                            Background="{Binding Galben}"
                            Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="INVENTAR"
                                   FontFamily="Segoe UI Black"
                                   FontSize="22"
                                   FontWeight="Black"
                                   Foreground="{Binding Galben}"/>
                        <TextBlock Text="Gestiune articole &amp; echipamente"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="{Binding Galben}"
                                   Opacity="0.55"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Background="{Binding Galben}"
                        VerticalAlignment="Center">
                    <TextBlock Text="🥊"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ROW 1 · STATS STRIP -->
        <Border Grid.Row="1"
                Background="{Binding Negru}"
                Padding="28,14,28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="10"
                        Background="{Binding Gri}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="TOTAL ARTICOLE"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Galben}"
                                   Opacity="0.7"/>
                        <TextBlock Text="{Binding Articole.Count}"
                                   FontFamily="Segoe UI Black"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="{Binding Galben}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ROW 2 · TOOLBAR -->
        <Border Grid.Row="2"
                Background="{Binding Negru}"
                Padding="28,0,28,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8"
                        Background="{Binding Gri}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.5"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SearchBox}"
                                 Background="Transparent"
                                 Text="{Binding Filtru, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{Binding Galben}"
                                 CaretBrush="{Binding Galben}"
                                 Padding="4,0,12,0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Cantitate:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{Binding Galben}"
                               FontFamily="Segoe UI Semibold"
                               FontSize="12"/>

                    <Border BorderBrush="{Binding Galben}"
                            BorderThickness="0,0,0,2"
                            Margin="0,0,10,0">
                        <TextBox Width="70"
                                 Height="35"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding Cantitate, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{Binding Galben}"
                                 CaretBrush="{Binding Galben}"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                  PreviewTextInput="TextBox_PreviewTextInput"/>
                    </Border>

                    <Button Style="{StaticResource ActionButton}"
                            Command="{Binding AdaugareArticol}"
                            Background="{Binding Galben}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                       Foreground="{Binding Negru}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="ADAUGĂ ARTICOL"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Negru}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButton}"
                            Command="{Binding VanzareArticol}"
                            Background="{Binding Rosu}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↑" FontSize="15" FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="VÂNZARE"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="11"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButton}"
                            Command="{Binding CumparareArticol}"
                            Background="{Binding Gri}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓" FontSize="15" FontWeight="Bold"
                                       Foreground="{Binding Galben}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="CUMPĂRARE"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="11"
                                       Foreground="{Binding Galben}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 3 · ITEMS GRID -->
        <Border Grid.Row="3"
                Background="{Binding Negru}"
                Padding="20,0,20,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                </ScrollViewer.Resources>

                <ListBox ItemsSource="{Binding Articolee}"
                         SelectedItem="{Binding SelectedArticol, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>

                            <!-- ═══ ARTICLE CARD ═══ -->
                            <Border x:Name="ArticleCardBorder"
                                    Style="{StaticResource ArticleCard}"
                                    Background="{Binding Gri}"
                                    Width="220">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- IMAGE -->
                                    <Border Grid.Row="0"
                                            CornerRadius="12,12,0,0"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Border Background="{Binding Negru}" Opacity="0.5"/>
                                            <Image Source="{Binding ProfileImage}"
                                                   Stretch="UniformToFill"/>

                                            <!-- STOCK -->
                                            <Border HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="10"
                                                    CornerRadius="20"
                                                    Padding="10,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding stoc}" Value="0">
                                                                <Setter Property="Background" Value="#A04747"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Stoc: " Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="{Binding stoc}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- INFO -->
                                    <Border Grid.Row="1" Padding="14,10,14,4">
                                        <TextBlock Text="{Binding denumire}"
                                                   Foreground="{Binding Galben}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <!-- PRICES -->
                                    <Border Grid.Row="2" Padding="14,4,14,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="CUMPĂRARE"
                                                           Foreground="{Binding Galben}"
                                                           Opacity="0.6"
                                                           FontSize="9"/>
                                                <TextBlock Text="{Binding pretcumparare}"
                                                           Foreground="{Binding Galben}"
                                                           FontSize="15"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="VÂNZARE"
                                                           Foreground="{Binding Rosu}"
                                                           FontSize="9"/>
                                                <TextBlock Text="{Binding pretvazare}"
                                                           Foreground="{Binding Rosu}"
                                                           FontSize="15"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- ACTIONS -->
                                    <Border Grid.Row="3"
                                            Background="{Binding Negru}"
                                            Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Profit:"
                                                       Foreground="{Binding Galben}"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding EditareArticol}"
                                                    Background="{Binding Gri}"
                                                    Margin="0,0,6,0">
                                                <TextBlock Text="✏" Foreground="{Binding Galben}"/>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding StergereArticol}"
                                                    Background="{Binding Rosu}">
                                                <TextBlock Text="🗑" Foreground="White"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Border>

                            <!-- Hover / Selected triggers on the card -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="ArticleCardBorder" Property="Background" Value="{Binding Negru}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="ArticleCardBorder" Property="Background" Value="{Binding Negru}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>

                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </ScrollViewer>
        </Border>

    </Grid>
</Window>