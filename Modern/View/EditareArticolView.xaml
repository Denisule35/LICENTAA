<Window x:Class="Modern.View.EditareArticolView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Modern.View"
        mc:Ignorable="d"
        Title="Adaugare Articol"
        Height="600" Width="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>

        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Height="40" CornerRadius="8" Background="{Binding Galben}">
                            <Border.Effect>
                                <DropShadowEffect Color="#D8A25E" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBoxBorder" TargetType="Border">
            <Setter Property="Background" Value="{Binding Negru}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="Height" Value="38"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{Binding Galben}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding Galben}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border Margin="15">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <Border Background="Transparent" CornerRadius="18"/>
        </Border>

        <Border x:Name="RootBorder"
                Background="{Binding Gri}"
                BorderBrush="{Binding Galben}"
                BorderThickness="1.5"
                CornerRadius="18"
                Margin="15"
                Opacity="0">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock FontSize="28" FontFamily="Georgia" FontWeight="Bold" Foreground="{Binding Galben}" Text="Editare Articol"/>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="28" Height="28" 
                            Content="✕" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="Iesire">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Background="{Binding Rosu}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="DENUMIRE ARTICOL" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource ModernTextBoxBorder}">
                                <TextBox Text="{Binding Denumire, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" Foreground="White" 
                                         VerticalContentAlignment="Center" Padding="8,0" CaretBrush="{Binding Galben}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="STOC DISPONIBIL" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource ModernTextBoxBorder}">
                                <TextBox Text="{Binding Stoc, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" Foreground="White" 
                                         VerticalContentAlignment="Center" Padding="8,0" CaretBrush="{Binding Galben}"/>
                            </Border>
                        </StackPanel>

                        <UniformGrid Columns="2" Margin="0,0,0,15">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="PREȚ CUMPĂRARE" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource ModernTextBoxBorder}">
                                    <TextBox Text="{Binding Pretcumparare, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="Transparent" BorderThickness="0" Foreground="White" 
                                             VerticalContentAlignment="Center" Padding="8,0" CaretBrush="{Binding Galben}"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="PREȚ VÂNZARE" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource ModernTextBoxBorder}">
                                    <TextBox Text="{Binding Pretvanzare, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="Transparent" BorderThickness="0" Foreground="White" 
                                             VerticalContentAlignment="Center" Padding="8,0" CaretBrush="{Binding Galben}"/>
                                </Border>
                            </StackPanel>
                        </UniformGrid>

                        <CheckBox IsChecked="{Binding EsteEchipament}" 
                                  Content="Este echipament sportiv" 
                                  Foreground="White" 
                                  FontFamily="Consolas" 
                                  FontSize="12"
                                  Cursor="Hand"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="IMAGINE ARTICOL" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <Button Command="{Binding EditarePozaArticol}"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="ImgContainer">

                                        <Ellipse Width="120"
                         Height="120"
                         Stroke="#44FFFFFF"
                         StrokeThickness="1.5"
                         StrokeDashArray="4 3"/>

                                        <Ellipse Width="110"
                         Height="110">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding ArticolImage}"
                                    Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                    </Grid>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                         Value="True">
                                            <Setter TargetName="ImgContainer"
                            Property="Opacity"
                            Value="0.75"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </StackPanel>
                </Grid>

                <Button Grid.Row="2"
                        Command="{Binding EditeazaArticol}"
                        Style="{StaticResource GoldButton}"
                        Content="＋ SALVEAZĂ ARTICOL" 
                        Foreground="{Binding Gri}" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        FontSize="13" 
                        Margin="0,15,0,0"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>