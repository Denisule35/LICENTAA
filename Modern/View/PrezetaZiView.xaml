<Window x:Class="Modern.View.PrezetaZiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Modern.View"
        mc:Ignorable="d"
        Title="Prezență Zi"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"
                             AccelerationRatio="0.3"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{Binding Negru}"
            CornerRadius="20"
            BorderBrush="{Binding Galben}"
            BorderThickness="2"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="30" ShadowDepth="10"/>
        </Border.Effect>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Prezență Zi"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{Binding Galben}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <!-- Minimize Button -->
                <Button x:Name="btnMinimize"
                        Grid.Column="1"
                        BorderThickness="0"
                        Content="−"
                        Foreground="White"
                        FontSize="20"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnMinimize_Click"
                        Width="40"
                        Height="40">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{Binding Galben}"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFA726"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                </Border.Effect>
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Close Button -->
                <Button x:Name="btnClose"
                        Grid.Column="3"
                        BorderThickness="0"
                        Content="×"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        Width="40"
                        Height="40">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{Binding Rosu}"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D32F2F"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="5" ShadowDepth="2"/>
                                </Border.Effect>
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content Area -->
            <Border Grid.Row="2"
                    Background="{Binding Gri}"
                    CornerRadius="15"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PREZENTI Column -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Prezenti Header -->
                        <Border Grid.Row="0"
                                Background="{Binding Negru}"
                                CornerRadius="10"
                                BorderBrush="{Binding Galben}"
                                BorderThickness="2"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="✓"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding Galben}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="Prezenți"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding Galben}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Prezenti List -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent">
                                                    <Track Name="PART_Track" IsDirectionReversed="true" Width="6">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Command="ScrollBar.LineUpCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Border Background="{Binding DataContext.Galben, RelativeSource={RelativeSource AncestorType=Window}}" CornerRadius="3" Margin="1"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Command="ScrollBar.LineDownCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding Prezenti}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding DataContext.Negru, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Margin="0,0,0,8"
                                                CornerRadius="10"
                                                BorderBrush="{Binding DataContext.Galben, RelativeSource={RelativeSource AncestorType=Window}}"
                                                BorderThickness="1.5"
                                                Padding="12,10">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="6" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4"
                                                        Background="{Binding DataContext.Galben, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding DataContext.Galben, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Column="1"
                            Width="2"
                            Background="{Binding Galben}"
                            Opacity="0.3"
                            CornerRadius="1"
                            HorizontalAlignment="Center"/>

                    <!-- ABSENTI Column -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Absenti Header -->
                        <Border Grid.Row="0"
                                Background="{Binding Negru}"
                                CornerRadius="10"
                                BorderBrush="{Binding Rosu}"
                                BorderThickness="2"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="✗"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding Rosu}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="Absenți"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{Binding Rosu}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Absenti List -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent">
                                                    <Track Name="PART_Track" IsDirectionReversed="true" Width="6">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Command="ScrollBar.LineUpCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Border Background="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=Window}}" CornerRadius="3" Margin="1"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Command="ScrollBar.LineDownCommand" Style="{x:Null}" Template="{x:Null}" Background="Transparent" IsTabStop="False"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding Absenti}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding DataContext.Negru, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Margin="0,0,0,8"
                                                CornerRadius="10"
                                                BorderBrush="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=Window}}"
                                                BorderThickness="1.5"
                                                Padding="12,10">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="6" ShadowDepth="2"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4"
                                                        Background="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding DataContext.Rosu, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
