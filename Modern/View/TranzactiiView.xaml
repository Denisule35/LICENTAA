<Window x:Class="Modern.View.TranzactiiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tranzacții" Height="600" Width="750"
        Background="{Binding Negru}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="RowText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Summary cards -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total venituri -->
                <Border Grid.Column="0" Background="{Binding Gri}" CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="Total venituri" Style="{StaticResource SectionHeader}"
                                   Foreground="{Binding Galben}"/>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#1D9E75">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="+{0} lei">
                                    <Binding Path="TotalVenituri"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Total pierderi -->
                <Border Grid.Column="2" Background="{Binding Gri}" CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="Total pierderi" Style="{StaticResource SectionHeader}"
                                   Foreground="{Binding Galben}"/>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{Binding Rosu}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="-{0} lei">
                                    <Binding Path="TotalPierderi"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Sold net -->
                <Border Grid.Column="4" Background="{Binding Gri}" CornerRadius="10" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="Sold net" Style="{StaticResource SectionHeader}"
                                   Foreground="{Binding Galben}"/>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{Binding Galben}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} lei">
                                    <Binding Path="SoldNet"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Venituri list -->
            <Border Style="{StaticResource CardBorder}" Background="{Binding Gri}">
                <StackPanel>
                    <TextBlock Text="▲  VENITURI" Style="{StaticResource SectionHeader}"
                               Foreground="{Binding Galben}" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Venituri}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,0.5" Padding="0,7">
                                    <TextBlock Text="{Binding}" Style="{StaticResource RowText}"
                                               Foreground="#1D9E75"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#1A1D9E75" CornerRadius="6" Padding="10,7" Margin="0,10,0,0">
                        <Grid>
                            <TextBlock Text="Total venituri" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#5DCAA5" HorizontalAlignment="Left"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Foreground="#5DCAA5" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} lei">
                                        <Binding Path="TotalVenituri"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Pierderi list -->
            <Border Style="{StaticResource CardBorder}" Background="{Binding Gri}">
                <StackPanel>
                    <TextBlock Text="▼  PIERDERI" Style="{StaticResource SectionHeader}"
                               Foreground="{Binding Rosu}" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Pierderi}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,0.5" Padding="0,7">
                                    <TextBlock Text="{Binding}" Style="{StaticResource RowText}"
                                               Foreground="{Binding DataContext.Rosu,
                                                   RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#1AA04747" CornerRadius="6" Padding="10,7" Margin="0,10,0,0">
                        <Grid>
                            <TextBlock Text="Total pierderi" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Rosu}" HorizontalAlignment="Left"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       Foreground="{Binding Rosu}" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} lei">
                                        <Binding Path="TotalPierderi"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Button Content="+ Adaugă tranzacție suplimentară"
                    Command="{Binding AdaugaTranzactieSuplimentara}"
                    Background="{Binding Galben}"
                    Foreground="{Binding Negru}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Padding="0,12"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,4,0,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>